# Copy to .env (local) or set these in your host's dashboard (production).
# All optional — the app ships with working dev defaults.

# Web Push (VAPID). Generate your own with:  python generate_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Secret guarding GET /cron/morning?key=...
CRON_SECRET=change-me

# Persistent data directory (where state.json lives, local/dev). Default: app folder.
# DATA_DIR=/var/data

# Persistent storage for production (free hosts have ephemeral disks).
# Create a free Redis at https://upstash.com and paste its REST creds.
# If unset, the app uses the local state.json file.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# In-process scheduler (only for always-on hosts / VPS). Leave off for Render free.
# ENABLE_SCHEDULER=1
# MORNING_HOUR=8
